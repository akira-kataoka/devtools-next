{
  "manifest_version": 3,
  "name": "DevToolsNext",
  "version": "3.512.0",
  "description": "Salesforce 開発者・管理者向けユーティリティ拡張。SOQL/Apex 実行、レコード詳細、データエクスポート、API ビルダー、設計書自動生成、ユーザー・ライセンス管理ダッシュボードを 1 画面で提供。本番組織での破壊操作には確認ダイアログを挟みます。",
  "default_locale": "ja",
  "permissions": [
    "cookies",
    "storage",
    "activeTab",
    "scripting",
    "tabs",
    "contextMenus",
    "clipboardWrite",
    "alarms",
    "notifications"
  ],
  "host_permissions": [
    "https://*.salesforce.com/*",
    "https://*.force.com/*",
    "https://*.lightning.force.com/*",
    "https://*.my.salesforce.com/*",
    "https://*.cloudforce.com/*",
    "https://*.salesforce-setup.com/*",
    "https://*.salesforce-experience.com/*",
    "https://*.visualforce.com/*",
    "https://*.sandbox.my.salesforce.com/*",
    "<all_urls>"
  ],
  "background": {
    "service_worker": "js/background.js",
    "type": "module"
  },
  "action": {
    "default_title": "DevToolsNext",
    "default_popup": "html/popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "devtools_page": "html/devtools.html",
  "content_scripts": [
    {
      "matches": [
        "https://*.salesforce.com/*",
        "https://*.force.com/*",
        "https://*.lightning.force.com/*",
        "https://*.my.salesforce.com/*",
        "https://*.visualforce.com/*",
        "https://*.salesforce-setup.com/*",
        "https://*.salesforce-experience.com/*"
      ],
      "js": ["js/content.js"],
      "run_at": "document_idle"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["html/*.html", "css/*.css", "js/*.js", "icons/*.png", "VERSION.txt"],
      "matches": [
        "https://*.salesforce.com/*",
        "https://*.force.com/*",
        "https://*.lightning.force.com/*",
        "https://*.my.salesforce.com/*",
        "https://*.visualforce.com/*",
        "https://*.salesforce-setup.com/*",
        "https://*.salesforce-experience.com/*"
      ]
    }
  ]
}
